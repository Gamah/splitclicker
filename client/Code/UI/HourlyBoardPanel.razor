@using System
@using System.Collections.Generic
@using System.Threading.Tasks
@using Sandbox
@using Sandbox.UI
@using Splitclicker.Api
@using Splitclicker.Game
@namespace Splitclicker.UI
@inherits PanelComponent

@*
	The persistent "most clicks this hour" board (UTC, resets on the clock hour).
	Unlike LeaderboardPanel — which renders the per-round standings PUSHED inside
	round_result/game_over — this is the separate Postgres-backed competition board,
	fetched over HTTP (GET /api/v1/leaderboard/hourly).

	Fetching is deliberately infrequent so it never becomes a fan-in GET stampede
	(PLAN §3.5): one fetch on connect, then a refresh only when a round closes
	(when the player is between presses and looking at scores), throttled to at most
	once per RefreshInterval. The hot click path never touches HTTP.
*@

<root>
	<div class="board">
		<div class="title">HOURLY · TOP CLICKERS</div>
		<div class="reset">resets in @ResetCountdown()</div>
		<div class="divider"></div>
		@if ( _entries.Count == 0 )
		{
			<div class="empty">@(_loaded ? "No scores this hour yet" : "loading…")</div>
		}
		else
		{
			@for ( int i = 0; i < _entries.Count; i++ )
			{
				var s = _entries[i];
				<div class="row @(IsMe( s ) ? "me" : "")">
					<div class="rank">@(i + 1)</div>
					<div class="name">@DisplayName( s )</div>
					<div class="pts">@s.Points</div>
				</div>
			}
		}
	</div>
</root>

<style>
	root {
		width: 100%;
		height: 100%;
		align-items: flex-start;
		justify-content: flex-start;
		pointer-events: none;
	}

	.board {
		flex-direction: column;
		width: 260px;
		margin-top: 18px;
		margin-left: 18px;
		background-color: rgba(7, 5, 26, 0.82);
		border: 1.5px solid rgba(255, 255, 255, 0.12);
		border-radius: 10px;
		padding: 12px 14px;
		gap: 3px;
	}

	.title {
		font-size: 14px;
		font-weight: bold;
		color: rgba(255, 255, 255, 0.85);
		letter-spacing: 1px;
		justify-content: center;
	}

	.reset {
		font-size: 11px;
		color: rgba(255, 255, 255, 0.5);
		justify-content: center;
		margin-bottom: 4px;
	}

	.divider {
		height: 1px;
		background-color: rgba(255, 255, 255, 0.1);
		margin-bottom: 5px;
	}

	.row {
		flex-direction: row;
		align-items: center;
		font-size: 13px;
		color: rgba(255, 255, 255, 0.78);
		padding: 2px 5px;
		border-radius: 4px;
	}

	.row.me { background-color: rgba(6, 214, 160, 0.15); }

	.rank { width: 24px; color: rgba(255, 255, 255, 0.4); font-size: 12px; }
	.name { flex-grow: 1; overflow: hidden; white-space: nowrap; }
	.pts { color: #06d6a0; font-weight: bold; }

	.empty {
		justify-content: center;
		font-size: 12px;
		color: rgba(255, 255, 255, 0.35);
		margin-top: 4px;
	}
</style>

@code {
	// Show the top slice only — the board panel is a glanceable sidebar, not the
	// full 100-deep list the API can return.
	const int DisplayLimit = 10;
	const float RefreshInterval = 20f;

	List<Standing> _entries = new();
	bool _loaded;
	bool _fetching;
	RealTimeSince _lastFetch;
	GamePhase _lastPhase = GamePhase.Connecting;

	protected override void OnTreeFirstBuilt() => _ = Refresh();

	protected override void OnUpdate()
	{
		var phase = ClickController.Instance?.Phase ?? GamePhase.Connecting;
		// Refresh when a round just closed (the player is reading scores between
		// presses), throttled so rapid result→pending churn can't spam the endpoint.
		bool roundJustClosed = phase != _lastPhase &&
			( phase == GamePhase.Result || phase == GamePhase.GameOver );
		_lastPhase = phase;
		if ( roundJustClosed && _lastFetch > RefreshInterval )
			_ = Refresh();
	}

	async Task Refresh()
	{
		if ( _fetching ) return;
		_fetching = true;
		_lastFetch = 0;
		try
		{
			var board = await ApiClient.GetHourlyLeaderboard( DisplayLimit );
			_entries = board ?? new List<Standing>();
			_loaded = true;
			StateHasChanged();
		}
		finally
		{
			_fetching = false;
		}
	}

	static bool IsMe( Standing s )
	{
		var tag = ClickController.Instance?.Tag;
		return !string.IsNullOrEmpty( tag ) && s.Tag == tag;
	}

	// Show the player's name (claimed username or Steam display name, resolved
	// server-side), never the opaque hex tag.
	static string DisplayName( Standing s ) =>
		!string.IsNullOrWhiteSpace( s.Username ) ? s.Username : "anonymous";

	// Wall-clock time left until the UTC hour ticks over (when the board resets),
	// as MM:SS — not a rolling 60-minute window.
	static string ResetCountdown()
	{
		var now = DateTime.UtcNow;
		var nextHour = now.Date.AddHours( now.Hour + 1 );
		var left = nextHour - now;
		return $"{(int)left.TotalMinutes:D2}:{left.Seconds:D2}";
	}

	// Include the seconds-remaining so the countdown re-renders as it ticks.
	protected override int BuildHash() => HashCode.Combine(
		_entries.Count, _loaded, ClickController.Instance?.Tag, (int)(DateTime.UtcNow - DateTime.UtcNow.Date).TotalSeconds );
}
