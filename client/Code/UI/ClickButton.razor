@using System
@using Sandbox
@using Sandbox.UI
@using Splitclicker.Game
@namespace Splitclicker.UI
@inherits PanelComponent

@*
	The one global button. The handler does nothing but enqueue the click send —
	no allocation, no awaiting render — so input latency is minimal. Its enabled
	state and scoring eligibility share one source: ClickController.CanClick.
*@

<root>
	<div class="btn @StateClass()" onclick="@OnPress">
		<div class="label">@Label()</div>
	</div>
</root>

<style>
	root {
		width: 100%;
		height: 100%;
		flex-direction: column;
		align-items: center;
		justify-content: center;
	}

	/* Fixed square (the ScreenPanel auto-scales to a 1080-tall reference) so the
	   button is a true circle, centered on screen, at ~70% of the screen height. */
	.btn {
		width: 760px;
		height: 760px;
		border-radius: 50%;
		align-items: center;
		justify-content: center;
		background-color: #e63946; /* red: not clickable */
		border: 8px solid rgba(255, 255, 255, 0.14);
		transition: all 0.08s ease-out;
		pointer-events: all;
		cursor: default;
	}

	.label {
		font-size: 64px;
		font-weight: bold;
		color: rgba(255, 255, 255, 0.85);
		letter-spacing: 3px;
	}

	/* green only while a valid click can actually score */
	.btn.armed {
		background-color: #06d6a0;
		border-color: #ffffff;
		cursor: pointer;
		transform: scale(1.02);
	}

	.btn.armed .label { color: white; }
	.btn.armed:active { transform: scale(0.98); }
</style>

@code {
	void OnPress() => ClickController.Instance?.SendClick();

	bool Armed => ClickController.Instance?.CanClick ?? false;

	// Green ("armed") only while a valid click can score; red (base) otherwise.
	string StateClass() => Armed ? "armed" : "";

	string Label()
	{
		var c = ClickController.Instance;
		if ( c == null ) return "…";
		return c.Phase switch
		{
			GamePhase.Armed => "CLICK!",
			GamePhase.Pending => "WAIT…",
			GamePhase.Result => "ROUND OVER",
			GamePhase.GameOver => "GAME OVER",
			GamePhase.Disconnected => "OFFLINE",
			_ => "…",
		};
	}

	protected override int BuildHash() => HashCode.Combine( Armed, ClickController.Instance?.Phase ?? GamePhase.Connecting );
}
