@using System
@using Sandbox
@using Sandbox.UI
@using Splitclicker.Game
@namespace Splitclicker.UI
@inherits PanelComponent

@*
	The one global button (a colored circle) dead-center on the screen, with the status
	HUD overlaid centered on top of it and the "clicks sent" tally just beneath. root is
	a full-screen absolute overlay (not a flex cell), so the button centers on the screen
	rather than on the space between the side boards, and the HUD — also screen-centered —
	lands exactly on it. The press handler only enqueues the send — minimal input latency.
*@

<root>
	<div class="btn @StateClass()" onclick="@OnPress"></div>

	<div class="hud">
		<div class="round">Round @(C?.Round ?? 0) / @(C?.Of ?? 0)</div>
		<div class="state @PhaseClass()">@PhaseText()</div>
		<div class="meta">
			<div class="score">You: @(C?.MyPoints ?? 0)</div>
			<div class="sep">·</div>
			<div class="players">@(C?.Players ?? 0) online</div>
			<div class="sep">·</div>
			<div class="clicks">@(C?.ClicksToWin ?? 0) clicks exist for this round</div>
		</div>
		@if ( C?.Phase == GamePhase.Pending && (C?.ArmMaxSec ?? 0) > 0 )
		{
			<div class="arm">arms in @(C.ArmMinSec)–@(C.ArmMaxSec)s</div>
		}
		@if ( (C?.PenaltyMs ?? 0) > 0 )
		{
			<div class="penalty">throttled +@(C.PenaltyMs)ms</div>
		}
	</div>

	<div class="clicks-sent">clicks sent: @(C?.ClicksSent ?? 0)</div>
</root>

<style>
	/* Full-screen overlay so the button is centered on the SCREEN, not on a flex
	   cell wedged between the side boards. Transparent + pointer-events:none, so
	   only the circle itself is interactive and the side panels show through. */
	root {
		position: absolute;
		top: 0;
		left: 0;
		right: 0;
		bottom: 0;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		pointer-events: none;
	}

	/* Fixed square (the ScreenPanel auto-scales to a 1080-tall reference) so the
	   button is a true circle, centered, at ~70% of screen height. */
	.btn {
		width: 700px;
		height: 700px;
		border-radius: 50%;
		background-color: #00e5ff; /* TEMP DIAGNOSTIC CANARY: was #e63946 red — revert after confirming reload */
		border: 8px solid rgba(255, 255, 255, 0.14);
		transition: all 0.08s ease-out;
		pointer-events: all;
		cursor: default;
	}

	/* green only while a valid click can actually score */
	.btn.armed {
		background-color: #06d6a0;
		border-color: #ffffff;
		cursor: pointer;
		transform: scale(1.02);
	}

	.btn.armed:active { transform: scale(0.98); }

	/* HUD overlaid dead-center on the button; clicks fall through to the button. */
	.hud {
		position: absolute;
		top: 0;
		left: 0;
		right: 0;
		bottom: 0;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		gap: 10px;
		pointer-events: none;
	}

	.round {
		font-size: 22px;
		font-weight: bold;
		color: rgba(255, 255, 255, 0.85);
		letter-spacing: 1px;
	}

	.state {
		font-size: 54px;
		font-weight: bold;
		color: rgba(255, 255, 255, 0.9);
		letter-spacing: 3px;
	}

	.state.armed { color: #ffffff; }
	.state.offline { color: #ffd166; }

	.meta {
		flex-direction: row;
		gap: 10px;
		align-items: center;
		font-size: 18px;
		font-weight: bold;
		color: rgba(255, 255, 255, 0.85);
	}

	.meta .sep { color: rgba(255, 255, 255, 0.4); }
	.meta .score { color: #06d6a0; }

	.arm {
		font-size: 16px;
		font-weight: bold;
		color: rgba(255, 255, 255, 0.6);
		letter-spacing: 1px;
	}

	.penalty {
		font-size: 16px;
		font-weight: bold;
		color: #ffd166;
	}

	/* Centered just under the circle: the button is 700px (350px radius) centered
	   on screen, so 360px below screen-center sits 10px below its bottom edge —
	   resolution-independent in the 1080-tall reference. */
	.clicks-sent {
		position: absolute;
		top: 50%;
		margin-top: 360px;
		left: 0;
		right: 0;
		justify-content: center;
		font-size: 22px;
		font-weight: bold;
		color: rgba(255, 255, 255, 0.65);
		letter-spacing: 1px;
		pointer-events: none;
	}
</style>

@code {
	ClickController C => ClickController.Instance;

	void OnPress() => ClickController.Instance?.SendClick();

	bool Armed => ClickController.Instance?.CanClick ?? false;

	// Green ("armed") only while a valid click can score; red (base) otherwise.
	string StateClass() => Armed ? "armed" : "";

	string PhaseText() => C?.Phase switch
	{
		GamePhase.Armed => "CLICK!",
		GamePhase.Pending => "WAIT…",
		GamePhase.Result => "ROUND OVER",
		GamePhase.GameOver => "GAME OVER",
		GamePhase.Disconnected => "RECONNECTING…",
		GamePhase.Connecting => "CONNECTING…",
		_ => "",
	};

	string PhaseClass() => C?.Phase switch
	{
		GamePhase.Armed => "armed",
		GamePhase.Disconnected => "offline",
		_ => "",
	};

	protected override int BuildHash() => HashCode.Combine(
		HashCode.Combine( C?.Phase ?? GamePhase.Connecting, C?.Round ?? 0, C?.Of ?? 0, C?.MyPoints ?? 0,
			C?.Players ?? 0, C?.ClicksToWin ?? 0, C?.PenaltyMs ?? 0, C?.ClicksSent ?? 0 ),
		C?.ArmMaxSec ?? 0 );
}
