@using System
@using System.Collections.Generic
@using System.Threading.Tasks
@using Sandbox
@using Sandbox.UI
@using Splitclicker.Api
@using Splitclicker.Game
@namespace Splitclicker.UI
@inherits PanelComponent

@*
	The career "hours won" board, top-right: how many UTC clock-hours each player
	has topped. The server credits the hour's top scorer when the hour rolls over;
	this fetches that board (GET /api/v1/leaderboard/hours-won) on the same cadence
	as the hourly board — once on connect, then when a round closes, throttled — so
	it never becomes a fan-in GET stampede.
*@

<root>
	<div class="board">
		<div class="title">HOURS WON</div>
		<div class="divider"></div>
		@if ( _entries.Count == 0 )
		{
			<div class="empty">@(_loaded ? "No hours won yet" : "loading…")</div>
		}
		else
		{
			@for ( int i = 0; i < _entries.Count; i++ )
			{
				var s = _entries[i];
				<div class="row @(IsMe( s ) ? "me" : "")">
					<div class="rank">@(i + 1)</div>
					<div class="name">@DisplayName( s )</div>
					<div class="pts">@s.Points</div>
				</div>
			}
		}
	</div>
</root>

<style>
	/* Pinned hard against the right edge (the session board's mirror image). */
	root {
		position: absolute;
		top: 0;
		right: 0;
		width: 300px;
		height: 100%;
		align-items: flex-end;
		justify-content: flex-start;
		pointer-events: none;
	}

	.board {
		flex-direction: column;
		width: 280px;
		margin-top: 18px;
		margin-right: 14px;
		background-color: rgba(7, 5, 26, 0.82);
		border: 1.5px solid rgba(255, 255, 255, 0.12);
		border-radius: 10px;
		padding: 12px 14px;
		gap: 3px;
	}

	.title {
		font-size: 14px;
		font-weight: bold;
		color: rgba(255, 255, 255, 0.85);
		letter-spacing: 1px;
		justify-content: center;
		margin-bottom: 4px;
	}

	.divider {
		height: 1px;
		background-color: rgba(255, 255, 255, 0.1);
		margin-bottom: 5px;
	}

	.row {
		flex-direction: row;
		align-items: center;
		font-size: 13px;
		color: rgba(255, 255, 255, 0.78);
		padding: 2px 5px;
		border-radius: 4px;
	}

	.row.me { background-color: rgba(255, 209, 102, 0.15); }

	.rank { width: 24px; color: rgba(255, 255, 255, 0.4); font-size: 12px; }
	.name { flex-grow: 1; overflow: hidden; white-space: nowrap; }
	.pts { color: #ffd166; font-weight: bold; }

	.empty {
		justify-content: center;
		font-size: 12px;
		color: rgba(255, 255, 255, 0.35);
		margin-top: 4px;
	}
</style>

@code {
	const int DisplayLimit = 10;
	const float RefreshInterval = 20f;

	List<Standing> _entries = new();
	bool _loaded;
	bool _fetching;
	RealTimeSince _lastFetch;
	GamePhase _lastPhase = GamePhase.Connecting;

	protected override void OnTreeFirstBuilt() => _ = Refresh();

	protected override void OnUpdate()
	{
		var phase = ClickController.Instance?.Phase ?? GamePhase.Connecting;
		// Hours-won only changes on the clock hour, but a round close is a cheap,
		// natural moment to refresh (the player is between presses), throttled.
		bool roundJustClosed = phase != _lastPhase &&
			( phase == GamePhase.Result || phase == GamePhase.GameOver );
		_lastPhase = phase;
		if ( roundJustClosed && _lastFetch > RefreshInterval )
			_ = Refresh();
	}

	async Task Refresh()
	{
		if ( _fetching ) return;
		_fetching = true;
		_lastFetch = 0;
		try
		{
			var board = await ApiClient.GetHoursWonLeaderboard( DisplayLimit );
			_entries = board ?? new List<Standing>();
			_loaded = true;
			StateHasChanged();
		}
		finally
		{
			_fetching = false;
		}
	}

	static bool IsMe( Standing s )
	{
		var tag = ClickController.Instance?.Tag;
		return !string.IsNullOrEmpty( tag ) && s.Tag == tag;
	}

	static string DisplayName( Standing s ) =>
		!string.IsNullOrWhiteSpace( s.Username ) ? s.Username : "anonymous";

	protected override int BuildHash() => HashCode.Combine( _entries.Count, _loaded, ClickController.Instance?.Tag );
}
