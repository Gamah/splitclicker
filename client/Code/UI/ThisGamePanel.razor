@using System
@using System.Collections.Generic
@using Sandbox
@using Sandbox.UI
@using Splitclicker.Api
@using Splitclicker.Game
@namespace Splitclicker.UI
@inherits PanelComponent

@*
	The "session" board: the current game's cumulative standings, shown constantly
	on the left (pushed inside round_result/game_over — never fetched, and never a
	round-over-only pop-up). The between-round/final standings live here now.
*@

<root>
	<div class="board">
		<div class="title">SESSION · TOP CLICKERS</div>
		<div class="divider"></div>
		@if ( Entries.Count == 0 )
		{
			<div class="empty">No scores yet</div>
		}
		else
		{
			@for ( int i = 0; i < Entries.Count && i < DisplayLimit; i++ )
			{
				var s = Entries[i];
				<div class="row @(IsMe( s ) ? "me" : "")">
					<div class="rank">@(i + 1)</div>
					<div class="name">@DisplayName( s )</div>
					<div class="pts">@s.Points</div>
				</div>
			}
		}
	</div>
</root>

<style>
	/* Left column of the HUD row: fixed width so the center button gets the rest. */
	root {
		width: 300px;
		flex-shrink: 0;
		height: 100%;
		align-items: flex-start;
		justify-content: flex-start;
		pointer-events: none;
	}

	.board {
		flex-direction: column;
		width: 280px;
		margin-top: 18px;
		margin-left: 14px;
		background-color: rgba(7, 5, 26, 0.82);
		border: 1.5px solid rgba(255, 255, 255, 0.12);
		border-radius: 10px;
		padding: 12px 14px;
		gap: 3px;
	}

	.title {
		font-size: 14px;
		font-weight: bold;
		color: rgba(255, 255, 255, 0.85);
		letter-spacing: 1px;
		justify-content: center;
		margin-bottom: 4px;
	}

	.divider {
		height: 1px;
		background-color: rgba(255, 255, 255, 0.1);
		margin-bottom: 5px;
	}

	.row {
		flex-direction: row;
		align-items: center;
		font-size: 13px;
		color: rgba(255, 255, 255, 0.78);
		padding: 2px 5px;
		border-radius: 4px;
	}

	.row.me { background-color: rgba(6, 214, 160, 0.15); }

	.rank { width: 24px; color: rgba(255, 255, 255, 0.4); font-size: 12px; }
	.name { flex-grow: 1; overflow: hidden; white-space: nowrap; }
	.pts { color: #06d6a0; font-weight: bold; }

	.empty {
		justify-content: center;
		font-size: 12px;
		color: rgba(255, 255, 255, 0.35);
		margin-top: 4px;
	}
</style>

@code {
	const int DisplayLimit = 10;

	List<Standing> Entries => ClickController.Instance?.Standings ?? new List<Standing>();

	static bool IsMe( Standing s )
	{
		var tag = ClickController.Instance?.Tag;
		return !string.IsNullOrEmpty( tag ) && s.Tag == tag;
	}

	static string DisplayName( Standing s ) =>
		!string.IsNullOrWhiteSpace( s.Username ) ? s.Username : "anonymous";

	protected override int BuildHash() =>
		HashCode.Combine( Entries.Count, ClickController.Instance?.MyPoints ?? 0, ClickController.Instance?.Tag );
}
