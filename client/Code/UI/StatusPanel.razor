@using System
@using Sandbox
@using Sandbox.UI
@using Splitclicker.Game
@namespace Splitclicker.UI
@inherits PanelComponent

@*
	The dead-center HUD, overlaid on top of the button circle: round counter, the
	big current-state label, your score, the online count, and how many scoring
	clicks exist this round. pointer-events:none so presses fall through to the
	button beneath. Reads ClickController.Instance every frame.
*@

<root>
	<div class="hud">
		<div class="round">Round @C.Round / @C.Of</div>
		<div class="state @PhaseClass()">@PhaseText()</div>
		<div class="meta">
			<div class="score">You: @C.MyPoints</div>
			<div class="sep">·</div>
			<div class="players">@(C?.Players ?? 0) online</div>
			<div class="sep">·</div>
			<div class="clicks">@(C?.ClicksToWin ?? 0) clicks exist for this round</div>
		</div>
		@if ( C?.Phase == GamePhase.Pending && (C?.ArmMaxSec ?? 0) > 0 )
		{
			<div class="arm">arms in @(C.ArmMinSec)–@(C.ArmMaxSec)s</div>
		}
		@if ( (C?.PenaltyMs ?? 0) > 0 )
		{
			<div class="penalty">throttled +@(C.PenaltyMs)ms</div>
		}
	</div>
	<div class="clicks-sent">clicks sent: @(C?.ClicksSent ?? 0)</div>
</root>

<style>
	root {
		position: absolute;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		flex-direction: column;
		align-items: center;     /* dead center of the whole screen */
		justify-content: center;
		pointer-events: none;
	}

	.hud {
		flex-direction: column;
		align-items: center;
		gap: 10px;
	}

	.round {
		font-size: 22px;
		font-weight: bold;
		color: rgba(255, 255, 255, 0.85);
		letter-spacing: 1px;
	}

	.state {
		font-size: 56px;
		font-weight: bold;
		color: rgba(255, 255, 255, 0.9);
		letter-spacing: 3px;
	}

	.state.armed { color: #ffffff; }
	.state.offline { color: #ffd166; }

	.meta {
		flex-direction: row;
		gap: 10px;
		align-items: center;
		font-size: 18px;
		color: rgba(255, 255, 255, 0.85);
		font-weight: bold;
	}

	.meta .sep { color: rgba(255, 255, 255, 0.4); }
	.meta .score { color: #06d6a0; }

	.arm {
		font-size: 16px;
		font-weight: bold;
		color: rgba(255, 255, 255, 0.6);
		letter-spacing: 1px;
	}

	.penalty {
		font-size: 16px;
		font-weight: bold;
		color: #ffd166;
	}

	/* Directly under the button circle (its bottom edge sits at ~920px of the
	   1080 reference), centered horizontally. */
	.clicks-sent {
		position: absolute;
		top: 936px;
		left: 0;
		width: 100%;
		justify-content: center;
		font-size: 22px;
		font-weight: bold;
		color: rgba(255, 255, 255, 0.65);
		letter-spacing: 1px;
	}
</style>

@code {
	ClickController C => ClickController.Instance;

	string PhaseText() => C?.Phase switch
	{
		GamePhase.Armed => "CLICK!",
		GamePhase.Pending => "WAIT…",
		GamePhase.Result => "ROUND OVER",
		GamePhase.GameOver => "GAME OVER",
		GamePhase.Disconnected => "RECONNECTING…",
		GamePhase.Connecting => "CONNECTING…",
		_ => "",
	};

	string PhaseClass() => C?.Phase switch
	{
		GamePhase.Armed => "armed",
		GamePhase.Disconnected => "offline",
		_ => "",
	};

	protected override int BuildHash() =>
		HashCode.Combine( HashCode.Combine( C?.Phase ?? GamePhase.Connecting, C?.Round ?? 0, C?.Of ?? 0, C?.MyPoints ?? 0,
			C?.Players ?? 0, C?.ClicksToWin ?? 0, C?.PenaltyMs ?? 0, C?.ClicksSent ?? 0 ),
			C?.ArmMaxSec ?? 0 );
}
