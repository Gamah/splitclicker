# Copy to .env and adjust. Never commit .env.

# For LOCAL dev (make dev / make migrate-up), point at your Postgres:
DATABASE_URL=postgres://splitclicker@localhost:5432/splitclicker?sslmode=disable

PORT=6969

# Extra cross-origin allowlist for browser REST + WS upgrades, comma-separated
# (scheme + host, no trailing slash). Blank = same-origin only (the s&box client
# sends no Origin and is always allowed).
CORS_ALLOWED_ORIGINS=

# Skin image, winner-lock countdown, and game tunables live in data/config.json
# (copy data/config.json.example). RUNTIME_DIR overrides where data/ lives
# (default "data"; Docker sets /data).
