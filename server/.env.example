# Copy to .env and adjust. Never commit .env.

# For LOCAL dev (make dev / make migrate-up), point at your Postgres:
DATABASE_URL=postgres://splitclicker@localhost:5432/splitclicker?sslmode=disable

PORT=6969

# Extra cross-origin allowlist for browser REST + WS upgrades, comma-separated
# (scheme + host, no trailing slash). The s&box client sends no Origin and is
# always allowed; same-origin is too. Blank = same-origin only.
CORS_ALLOWED_ORIGINS=

# ── Skin-to-win image & winner-lock countdown ────────────────────────────────
# The image served at GET /api/v1/skin (a filename inside the media dir). Swap
# this to change the "skin to win" without rebuilding the client.
SKIN_IMAGE=skin2win.png
# Where the served images live. Defaults to ./media for `make dev`; the Docker
# image sets this to /media.
# MEDIA_DIR=media
# When the current winner is locked in (RFC3339). The client counts down to this
# ("Time until winner is locked in") and, once past, prompts for a new skin.
# 1AM CST on the 16th == 2026-06-16T01:00:00-06:00 == 07:00 UTC.
WINNER_LOCK_TIME=2026-06-16T07:00:00Z

# ── Game tunables (all optional; defaults in internal/game/config.go) ─────────
ARM_MIN_SEC=10
ARM_MAX_SEC=120
# N (scoring clicks per arm) = CLICKS_PER_PLAYER × connected players, floored at
# MIN_CLICKS. So the race scales with the crowd: 1 click each by default.
CLICKS_PER_PLAYER=1
MIN_CLICKS=1
ROUNDS_PER_GAME=10
# RACE_MAX_MS=5000
# RESULT_DISPLAY_MS=4000
# INTERMISSION_MS=5000
# BOARD_SIZE=20
